{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MLCommons system_desc_id.json",
  "description": "Validates system_desc_id.json per MLCommons submission rules section 5.7",
  "type": "object",
  "required": [
    "submitter",
    "division",
    "system_type",
    "status",
    "system_name",
    "number_of_nodes",
    "host_processors_per_node",
    "host_processor_model_name",
    "host_memory_capacity",
    "host_storage_type",
    "host_storage_capacity",
    "host_networking",
    "host_network_card_count",
    "host_networking_topology",
    "host_memory_configuration",
    "accelerators_per_node",
    "accelerator_model_name",
    "accelerator_host_interconnect",
    "accelerator_memory_configuration",
    "accelerator_memory_capacity",
    "accelerator_interconnect",
    "cooling",
    "framework",
    "other_software_stack",
    "operating_system"
  ],
  "properties": {
    "submitter":                      { "type": "string", "minLength": 1 },
    "division":                       { "type": "string", "enum": ["closed", "network", "open"] },
    "system_type":                    { "type": "string", "minLength": 1 },
    "system_type_detail":             { "type": "string" },
    "status":                         { "type": "string", "minLength": 1 },
    "system_name":                    { "type": "string", "minLength": 1 },
    "number_of_nodes":                { "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "string", "pattern": "^[0-9]+$" }] },
    "host_processors_per_node":       { "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "string", "pattern": "^[0-9]+$" }] },
    "host_processor_model_name":      { "type": "string", "minLength": 1 },
    "host_processor_core_count":      { "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "string", "pattern": "^[0-9]+$" }] },
    "host_processor_vcpu_count":      { "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "string", "pattern": "^[0-9]+$" }] },
    "host_processor_frequency":       { "type": "string" },
    "host_processor_caches":          { "type": "string" },
    "host_processor_interconnect":    { "type": "string" },
    "host_memory_capacity":           { "type": "string", "minLength": 1 },
    "host_storage_type":              { "type": "string", "minLength": 1 },
    "host_storage_capacity":          { "type": "string", "minLength": 1 },
    "host_networking":                { "type": "string", "minLength": 1 },
    "host_network_card_count":        { "type": "string", "minLength": 1 },
    "host_networking_topology":       { "type": "string", "minLength": 1 },
    "host_memory_configuration":      { "type": "string", "minLength": 1 },
    "accelerators_per_node":          { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "string", "pattern": "^[0-9]+$" }] },
    "accelerator_model_name":         { "type": "string", "minLength": 1 },
    "accelerator_host_interconnect":  { "type": "string", "minLength": 1 },
    "accelerator_frequency":          { "type": "string" },
    "accelerator_on-chip_memories":   { "type": "string" },
    "accelerator_memory_configuration": { "type": "string", "minLength": 1 },
    "accelerator_memory_capacity":    { "type": "string", "minLength": 1 },
    "accelerator_interconnect":       { "type": "string", "minLength": 1 },
    "accelerator_interconnect_topology": { "type": "string" },
    "cooling":                        { "type": "string", "minLength": 1 },
    "hw_notes":                       { "type": "string" },
    "framework":                      { "type": "string", "minLength": 1 },
    "other_software_stack":           { "type": ["string", "object"] },
    "operating_system":               { "type": "string", "minLength": 1 },
    "sw_notes":                       { "type": "string" },

    "boot_firmware_version":                      { "type": "string" },
    "management_firmware_version":                { "type": "string" },
    "other_hardware":                             { "type": "string" },
    "disk_controllers":                           { "type": "string" },
    "disk_drives":                                { "type": "string" },
    "filesystem":                                 { "type": "string" },
    "power_management":                           { "type": "string" },
    "power_supply_details":                       { "type": "string" },
    "power_supply_quantity_and_rating_watts":      { "type": "string" },
    "network_speed_mbit":                         { "type": "string" },
    "nics_enabled_connected":                     { "type": "string" },
    "nics_enabled_firmware":                      { "type": "string" },
    "nics_enabled_os":                            { "type": "string" },
    "number_of_type_nics_installed":              { "type": "string" },
    "accelerator_short_name":                     { "type": "string" },
    "private_id":                                 { "type": "string" },

    "is_network":                     { "type": "boolean" },
    "network_type":                   { "type": "string" },
    "network_media":                  { "type": "string" },
    "network_rate":                   { "type": "string" },
    "nic_loadgen":                    { "type": "string" },
    "number_nic_loadgen":             { "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "string", "pattern": "^[0-9]+$" }] },
    "net_software_stack_loadgen":     { "type": "string" },
    "network_protocol":               { "type": "string" },
    "number_connections":             { "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "string", "pattern": "^[0-9]+$" }] },
    "nic_sut":                        { "type": "string" },
    "number_nic_sut":                 { "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "string", "pattern": "^[0-9]+$" }] },
    "net_software_stack_sut":         { "type": "string" },
    "network_topology":               { "type": "string" }
  },
  "anyOf": [
    { "required": ["host_processor_core_count"] },
    { "required": ["host_processor_vcpu_count"] }
  ],
  "if": {
    "properties": { "division": { "const": "network" } },
    "required": ["division"]
  },
  "then": {
    "required": [
      "is_network",
      "network_type",
      "network_media",
      "network_rate",
      "nic_loadgen",
      "number_nic_loadgen",
      "net_software_stack_loadgen",
      "network_protocol",
      "number_connections",
      "nic_sut",
      "number_nic_sut",
      "net_software_stack_sut",
      "network_topology"
    ]
  },
  "additionalProperties": false
}
